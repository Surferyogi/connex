# Copy to ".env" and fill with YOUR new Supabase project's values.
# These two are SAFE to ship in the frontend — the anon key is public and is
# constrained by Row Level Security. The SECRET service key and the Anthropic
# key must NEVER appear here or in the frontend; they live only in Supabase.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
